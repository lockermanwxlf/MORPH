<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="morph">
  <xacro:property name="base_length" value="0.34"/>
  <xacro:property name="base_width" value="0.27"/>
  <xacro:property name="base_height" value="0.10"/>
  <xacro:property name="base_mass" value="6.0"/>

  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width" value="0.03"/>
  <xacro:property name="wheel_x" value="0.0"/>
  <xacro:property name="wheel_y" value="0.135"/>
  <xacro:property name="wheel_z" value="0.05"/>

  <xacro:property name="laser_x" value="0.15"/>
  <xacro:property name="laser_z" value="0.11"/>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height / 2.0}"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="morph_blue">
        <color rgba="0.08 0.44 0.78 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height / 2.0}"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${base_height / 2.0}"/>
      <mass value="${base_mass}"/>
      <inertia ixx="0.08" ixy="0.0" ixz="0.0" iyy="0.12" iyz="0.0" izz="0.16"/>
    </inertial>
  </link>

  <link name="left_wheel_link">
    <visual>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="dark">
        <color rgba="0.12 0.12 0.12 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="${wheel_x} ${wheel_y} ${wheel_z}"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel_link">
    <visual>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="dark"/>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="${wheel_x} ${-wheel_y} ${wheel_z}"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="laser">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.05"/>
      </geometry>
      <material name="laser_black">
        <color rgba="0.18 0.18 0.2 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="${laser_x} 0 ${laser_z}"/>
  </joint>
</robot>
