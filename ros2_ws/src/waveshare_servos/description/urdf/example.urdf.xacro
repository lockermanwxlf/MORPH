<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="waveshare_servos">
  <xacro:arg name="device_port" default="/dev/ttyUSB1"/>
  <xacro:arg name="baud_rate" default="921600"/>
  <xacro:arg name="io_timeout_ms" default="20"/>
  <xacro:arg name="enable_sync_read" default="false"/>
  <xacro:arg name="estimate_state_from_commands" default="true"/>

  <!-- Tunables: set to your real geometry -->
  <xacro:property name="wheel_radius" value="0.03175"/>      <!-- 3.1 cm -->
  <xacro:property name="wheel_width"  value="0.0254"/>      <!-- 2.5 cm -->
  <xacro:property name="wheel_sep"    value="0.1524"/>      <!-- distance between wheel centers -->
  
  <xacro:property name="wheel_x_front" value="0.0857"/>
  <xacro:property name="wheel_x_back"  value="-0.0857"/>
  <xacro:property name="wheel_y_left"  value="0.0762"/>
  <xacro:property name="wheel_y_right" value="-0.0762"/>  
  <xacro:property name="wheel_z"      value="${wheel_radius}"/>

  <xacro:property name="base_x"       value="0.00"/>      <!-- was 0.2 -->
  <xacro:property name="base_y"       value="0.00"/>      <!-- was 0.16 -->
  <xacro:property name="base_z"       value="0.00"/>       <!-- was 0.06 base height (centered) -->

  <!-- Base -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${wheel_z}"/>
      <geometry>
        <box size="${base_x} ${base_y} ${base_z}"/>
      </geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <inertial>
      <origin xyz="0 0 ${wheel_z}"/>
      <mass value="1.0"/>
      <inertia ixx="0.02" iyy="0.02" izz="0.02" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- FRONT LEFT WHEEL -->
  <link name="front_left_wheel_link">
    <visual>
      <!-- wheel geometry centered at the wheel link frame -->
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel_link"/>
    <!-- desired wheel center pose relative to base_link -->
    <origin xyz="${wheel_x_front} ${wheel_y_left} ${wheel_z}"/>
    <axis xyz="0 1 0"/>
    <limit velocity="100.0" effort="0.0"/>
  </joint>

  <!-- FRONT RIGHT WHEEL -->
  <link name="front_right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel_link"/>
    <origin xyz="${wheel_x_front} ${wheel_y_right} ${wheel_z}"/>
    <axis xyz="0 1 0"/>
    <limit velocity="100.0" effort="0.0"/>
  </joint>
  
  <!-- BACK LEFT WHEEL -->
  <link name="back_left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
  </link>

  <joint name="back_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_left_wheel_link"/>
    <origin xyz="${wheel_x_back} ${wheel_y_left} ${wheel_z}"/>
    <axis xyz="0 1 0"/>
    <limit velocity="100.0" effort="0.0"/>
  </joint>

  <!-- BACK RIGHT WHEEL -->
  <link name="back_right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
  </link>

  <joint name="back_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_right_wheel_link"/>
    <origin xyz="${wheel_x_back} ${wheel_y_right} ${wheel_z}"/>
    <axis xyz="0 1 0"/>
    <limit velocity="100.0" effort="0.0"/>
  </joint>

  <!-- ros2_control hardware mapping (your plugin + servo IDs) -->
  <xacro:include filename="$(find waveshare_servos)/description/ros2_control/example.ros2_control.xacro"/>
  <xacro:example_ws_ros2_control name="example_ws_ros2_control" 
                                 front_left_joint_name="front_left_wheel_joint" front_left_id="2"
                                 front_right_joint_name="front_right_wheel_joint" front_right_id="1"
                                 back_left_joint_name="back_left_wheel_joint" back_left_id="4"
                                 back_right_joint_name="back_right_wheel_joint" back_right_id="3"
                                 device_port="$(arg device_port)"
                                 baud_rate="$(arg baud_rate)"
                                 io_timeout_ms="$(arg io_timeout_ms)"
                                 enable_sync_read="$(arg enable_sync_read)"
                                 estimate_state_from_commands="$(arg estimate_state_from_commands)"/>

</robot>
